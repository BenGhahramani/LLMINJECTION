# -----------------------------------------------------------------------
# LLM backend — choose ONE of the two options below.
# Copy this file to .env and fill in the relevant values.
# -----------------------------------------------------------------------

# --- Option A: local Ollama (recommended, no API key needed) -----------
# Run ./setup_local.sh to install Ollama and set these automatically.
#
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b

# --- Option B: OpenAI API ----------------------------------------------
# Comment out the two lines above and uncomment this one.
#
# OPENAI_API_KEY=sk-...
